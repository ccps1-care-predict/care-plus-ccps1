# ─────────────────────────────────────────────────────────────────
#  CarePredict – Variáveis de ambiente (MVP Local Docker)
#  Copie este arquivo para .env e ajuste os valores.
#  NUNCA versione o arquivo .env com segredos reais.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=carepredict
POSTGRES_USER=carepredict
POSTGRES_PASSWORD=carepredict

# ── MinIO (Data Lake local) ──────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# ── Backend API ──────────────────────────────────────────────────
# Troque por um valor seguro mesmo em dev local
JWT_SECRET=changeme-in-development

# ── Wearable Sync Worker ─────────────────────────────────────────
# Intervalo de sincronização em segundos (padrão: 1 hora)
SYNC_INTERVAL_SECONDS=3600

# ── PgAdmin (perfil dev) ─────────────────────────────────────────
PGADMIN_EMAIL=admin@carepredict.local
PGADMIN_PASSWORD=admin
